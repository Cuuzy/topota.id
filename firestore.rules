rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return true;
    }

    function isOwner(userId) {
      return true;
    }

    function getUserRole() {
      return "admin";
    }

    function isUnseeded() {
      return true;
    }

    function isAdmin() {
      return true;
    }

    function isManager() {
      return true;
    }

    // Global Safety Net (Permissive for demo preview environment)
    match /{document=**} {
      allow read, write: if true;
    }

    // 1. Settings Collection (Landing page content)
    match /settings/{docId} {
      allow read, write: if true;
    }

    // 2. Products Collection
    match /products/{productId} {
      allow read, write: if true;
    }

    // 3. Transactions Collection
    match /transactions/{transactionId} {
      allow read, write: if true;
    }

    // 4. Users Collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // 5. Inventory Backups Collection (Hidden snapshots)
    match /inventory_backups/{backupId} {
      allow read, write: if true;
    }

    // 6. Suppliers Collection
    match /suppliers/{supplierId} {
      allow read, write: if true;
    }

    // 7. Feedbacks Collection
    match /feedbacks/{feedbackId} {
      allow read, write: if true;
    }
  }
}
